{
  "name": "dev-utils-hub",
  "productName": "Dev Utils Hub",
  "description": "A collection of developer utilities for daily tasks",
  "author": "Dev Utils Hub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite",
    "build": "electron-vite build",
    "build:web": "tsc -b && vite build",
    "type-check": "tsc -b --noEmit",
    "type-check:main": "tsc -p tsconfig.main.json --noEmit",
    "type-check:preload": "tsc -p tsconfig.preload.json --noEmit",
    "type-check:renderer": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron-vite preview",
    "dist": "npm run build && node scripts/optimize-for-build.cjs && electron-builder && node scripts/restore-package.cjs",
    "dist:mac": "npm run build && node scripts/optimize-for-build.cjs && electron-builder --mac && node scripts/restore-package.cjs",
    "dist:win": "npm run build && node scripts/optimize-for-build.cjs && electron-builder --win && node scripts/restore-package.cjs",
    "dist:linux": "npm run build && node scripts/optimize-for-build.cjs && electron-builder --linux && node scripts/restore-package.cjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "test:bench": "vitest bench",
    "test:mutation": "npx stryker run",
    "test:property": "vitest run --reporter=verbose src/renderer/utils/__tests__/*.property.test.ts",
    "test:a11y": "vitest run --reporter=verbose src/renderer/components/tools/__tests__/accessibility.test.tsx",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:visual": "playwright test e2e/visual-regression.spec.ts",
    "lighthouse": "npm run build:web && lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "lighthouse:upload": "lhci upload"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/react": "^10.22.0",
    "@sentry/types": "^7.120.4",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^11.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-localshortcut": "^3.2.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "i18next": "^25.6.0",
    "lucide-react": "^0.546.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^16.1.5",
    "react-router-dom": "^7.9.4",
    "sonner": "^2.0.7",
    "source-map": "^0.7.6",
    "tailwind-merge": "^3.3.1",
    "vite-plugin-pwa": "^1.1.0",
    "vlq": "^1.0.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^9.36.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.1",
    "@sentry/cli": "^2.57.0",
    "@sentry/vite-plugin": "^4.5.0",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.0.3",
    "@vitest/ui": "^4.0.1",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^4.0.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "fast-check": "^4.6.0",
    "globals": "^16.4.0",
    "happy-dom": "^20.0.8",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.0.1",
    "prettier": "^3.6.2",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vitest": "^4.0.1"
  }
}
